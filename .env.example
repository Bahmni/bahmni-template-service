# Port the service listens on
PORT=8080

# Base URL for OpenMRS (internal Docker network name)
OPENMRS_URL=http://openmrs:8080

# Absolute path to the templates directory.
# In production: mounted from standard-config Docker volume (do not change).
# In local dev: point to your standard-config checkout, e.g.:
#   TEMPLATES_DIR=/path/to/standard-config/print-templates
TEMPLATES_DIR=/etc/bahmni_config/print-templates

# Chromium binary path (provided by the Playwright Docker base image)
CHROMIUM_PATH=/ms-playwright/chromium-1148/chrome-linux/chrome

# Optional: OpenMRS service account credentials for local development.
# When set, the service uses Basic Auth instead of forwarding the browser cookie.
# Leave unset in production — nginx forwards the browser's JSESSIONID instead.
OPENMRS_USERNAME=superman
OPENMRS_PASSWORD=Admin123
