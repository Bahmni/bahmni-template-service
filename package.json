{
  "name": "bahmni-template-service",
  "version": "1.0.0",
  "description": "Bahmni configurable document rendering service",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --env-file=.env -e \"require('child_process').spawnSync('node', ['node_modules/.bin/ts-node-dev', '--respawn', '--transpile-only', 'src/server.ts'], {stdio: 'inherit', env: process.env})\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bwip-js": "^3.3.0",
    "express": "^4.19.2",
    "fhirpath": "^3.13.0",
    "nunjucks": "^3.2.4",
    "qrcode-svg": "^1.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/nunjucks": "^3.2.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
